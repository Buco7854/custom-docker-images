# Copy to .env and fill in real values. .env is gitignored — never commit it.
#
# The two CROWDSEC_*_BOUNCER_API_KEY values auto-register with LAPI on
# first start via the BOUNCER_KEY_* env vars on the crowdsec service —
# pick any long random string (openssl rand -hex 32). The matching
# bouncer-side config files must hold the SAME value:
#   CROWDSEC_BOUNCER_API_KEY     -> crowdsec_nginx-bouncer.conf  (API_KEY)
#   CROWDSEC_FW_BOUNCER_API_KEY  -> crowdsec_firewall-bouncer.yaml (api_key)

# --- CrowdSec bouncers -----------------------------------------------------
CROWDSEC_BOUNCER_API_KEY=your_nginx_bouncer_key_here
CROWDSEC_FW_BOUNCER_API_KEY=your_firewall_bouncer_key_here

# --- CrowdSec web UI -------------------------------------------------------
# The web UI authenticates to LAPI with MACHINE credentials (not a bouncer
# key). Register the machine once after the stack is up:
#   docker compose exec crowdsec cscli machines add "$CROWDSEC_UI_USER" \
#       --password "$CROWDSEC_UI_PASSWORD" -f /dev/null
# -f /dev/null is REQUIRED: it stops cscli from overwriting the crowdsec
# container's own /etc/crowdsec/local_api_credentials.yaml (bind-mounted
# under crowdsec_config/) — doing so would break the engine's own LAPI
# auth. We only want the DB registration, not the credentials-file dump.
CROWDSEC_UI_PORT=9321
# Single-stack value: reach LAPI over proxy_net by service name. Upstream's
# http://host.docker.internal:8080 is only for when the web UI runs in a
# separate compose project.
CROWDSEC_API_URL=http://crowdsec:8080
CROWDSEC_UI_USER=crowdsec-web-ui
CROWDSEC_UI_PASSWORD=replace-with-a-long-random-password
CROWDSEC_UI_DATA_PATH=./crowdsec-web-ui

# web UI performance tuning
CROWDSEC_LOOKBACK=5d
CROWDSEC_REFRESH=30s
CROWDSEC_IDLE_REFRESH=5m
CROWDSEC_IDLE_LIMIT=2m
CROWDSEC_CACHE_REFRESH=5m
CROWDSEC_ALERT_INCLUDE_ORIGINS=crowdsec,cscli
CROWDSEC_ALERT_EXCLUDE_ORIGINS=
CROWDSEC_ALERT_INCLUDE_CAPI=false
CROWDSEC_ALERT_INCLUDE_ORIGIN_EMPTY=false
CROWDSEC_ALERT_EXCLUDE_ORIGIN_EMPTY=false

# --- nginx-ui --------------------------------------------------------------
# Reload API key. Must match the [auth] ApiKey value in nginx-ui/app.ini —
# the bundled default is `changeme_replace_this`. Used by Certwarden's
# post-issuance hook to trigger `nginx -s reload` after writing certs.
NGINX_UI_API_KEY=changeme_replace_this

# --- Misc ------------------------------------------------------------------
TZ=Europe/Paris
