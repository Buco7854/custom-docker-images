# Copy to .env and fill in real values.
#
# All three CROWDSEC_*_API_KEY values are auto-registered with LAPI on
# first start via the `BOUNCER_KEY_*` env vars on the crowdsec service —
# you can pick any reasonably long random string. Generate with:
#   openssl rand -hex 32
# The bouncer-side config files (crowdsec/bouncer.conf,
# crowdsec/firewall-bouncer.yaml) must hold the SAME value.

# --- CrowdSec --------------------------------------------------------------
# Bouncer key for the nginx Lua bouncer.
# Must match API_KEY in crowdsec/bouncer.conf.
CROWDSEC_BOUNCER_API_KEY=your_nginx_bouncer_key_here

# Bouncer key for the firewall bouncer (iptables on the host).
# Must match api_key in crowdsec/firewall-bouncer.yaml.
CROWDSEC_FW_BOUNCER_API_KEY=your_firewall_bouncer_key_here

# Bouncer key for the CrowdSec web UI.
CROWDSEC_WEB_UI_API_KEY=your_web_ui_key_here

# --- Grafana ---------------------------------------------------------------
GRAFANA_PASSWORD=changeme

# --- nginx-ui --------------------------------------------------------------
# Reload API key. Must match the [auth] ApiKey value in nginx-ui/app.ini —
# the bundled default is `changeme_replace_this`. Used by Certwarden's
# post-issuance hook to trigger `nginx -s reload` after writing certs.
NGINX_UI_API_KEY=changeme_replace_this

# --- Misc ------------------------------------------------------------------
TZ=Europe/Paris
