# Copy to .env and fill in real values.

# --- CrowdSec --------------------------------------------------------------
# Bouncer key for the nginx Lua bouncer. The `BOUNCER_KEY_nginx` env var on
# the crowdsec service auto-registers this key on first start, so you can
# pick any reasonably long random string here:
#   openssl rand -hex 32
# It must match the API_KEY in crowdsec/bouncer.conf.
CROWDSEC_BOUNCER_API_KEY=your_bouncer_api_key_here

# Bouncer key for the web UI. Generate it AFTER `docker compose up -d`:
#   docker compose exec crowdsec cscli bouncers add crowdsec-web-ui
# Then paste the output here and `docker compose restart crowdsec-ui`.
CROWDSEC_WEB_UI_API_KEY=your_web_ui_api_key_here

# --- Grafana ---------------------------------------------------------------
GRAFANA_PASSWORD=changeme

# --- nginx-ui --------------------------------------------------------------
# Reload API key. Must match the [auth] ApiKey value in nginx-ui/app.ini —
# the bundled default is `changeme_replace_this`. Used by Certwarden's
# post-issuance hook to trigger `nginx -s reload` after writing certs.
NGINX_UI_API_KEY=changeme_replace_this

# --- Misc ------------------------------------------------------------------
TZ=Europe/Paris
