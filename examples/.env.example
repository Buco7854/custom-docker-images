# Copy to .env and fill in real values. Paths are not configurable here —
# the stack uses fixed relative paths under the compose directory. See the
# header of docker-compose.yml for the host directory layout.

# --- nginx-ui reload API ---------------------------------------------------
# generate with:  openssl rand -hex 32
RELOAD_API_KEY=replace-me-with-a-long-random-string

# --- CrowdSec --------------------------------------------------------------
# After `docker compose up -d crowdsec`, run:
#   docker exec crowdsec cscli bouncers add nginx-bouncer
# and paste the key here.
CROWDSEC_BOUNCER_API_KEY=

# CrowdSec web UI credentials (admin login for the dashboard at :3000)
CROWDSEC_UI_USER=admin
CROWDSEC_UI_PASSWORD=changeme

# --- Misc ------------------------------------------------------------------
TZ=Europe/Paris

# --- Optional: web UI tuning (leave as defaults unless you need to change) -
# CROWDSEC_UI_PORT=3000
# CROWDSEC_LOOKBACK=24h
# CROWDSEC_REFRESH=10
# CROWDSEC_IDLE_REFRESH=60
# CROWDSEC_IDLE_LIMIT=300
# CROWDSEC_CACHE_REFRESH=300
