# Copy to .env and fill in real values.

# --- nginx-ui reload API ---------------------------------------------------
# openssl rand -hex 32
RELOAD_API_KEY=replace-me-with-a-long-random-string

# --- CrowdSec --------------------------------------------------------------
# Persistent state directory (DB, machines, decisions). Bind-mounted into the
# crowdsec container at /var/lib/crowdsec/data AND used by crowdsec-web-ui.
DATA_PATH=/srv/crowdsec/data

# Bind-mounted into the crowdsec container at /etc/crowdsec — your parsers,
# whitelists, profiles, acquisition configs, appsec rules live here.
CROWDSEC_CONFIG_PATH=./crowdsec/config

# After `docker exec crowdsec cscli bouncers add nginx-bouncer`, paste the key.
CROWDSEC_BOUNCER_API_KEY=

# --- CrowdSec web UI -------------------------------------------------------
CROWDSEC_UI_PORT=3000
CROWDSEC_API_URL=http://crowdsec:8080
CROWDSEC_UI_USER=admin
CROWDSEC_UI_PASSWORD=changeme
CROWDSEC_LOOKBACK=24h
CROWDSEC_REFRESH=10
CROWDSEC_IDLE_REFRESH=60
CROWDSEC_IDLE_LIMIT=300
CROWDSEC_CACHE_REFRESH=300
CROWDSEC_ALERT_INCLUDE_ORIGINS=
CROWDSEC_ALERT_EXCLUDE_ORIGINS=
CROWDSEC_ALERT_INCLUDE_CAPI=true
CROWDSEC_ALERT_INCLUDE_ORIGIN_EMPTY=true
CROWDSEC_ALERT_EXCLUDE_ORIGIN_EMPTY=false

# --- Misc ------------------------------------------------------------------
TZ=Europe/Paris
